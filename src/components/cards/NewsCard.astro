---
import type { NewsItem } from "../../data/site";

interface Props extends NewsItem {}

const { image, alt, date, title, description } = Astro.props;
---

<article class="group flex flex-col md:flex-row gap-6 rounded-lg p-4 hover:bg-surface-container-low transition-colors duration-300">
  <div class="w-full md:w-1/2 aspect-video overflow-hidden rounded">
    <img
      alt={alt}
      class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
      src={image}
      loading="lazy"
    />
  </div>
  <div class="w-full md:w-1/2 flex flex-col justify-center">
    <span class="text-surface-tint font-bold text-xs mb-2">{date}</span>
    <h3
      class="font-headline text-headline-md text-lg mb-2 leading-snug group-hover:text-primary transition-colors"
    >
      {title}
    </h3>
    <p class="text-on-surface-variant text-body-sm line-clamp-2">{description}</p>
  </div>
</article>
