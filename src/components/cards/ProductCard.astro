---
import type { Product } from "../../data/products";

interface Props extends Product {}

const { image, category, title, description } = Astro.props;
---

<div
  class="bg-surface border border-surface-container-highest rounded-lg overflow-hidden group hover:border-primary-container/40 hover:shadow-md hover:-translate-y-1 transition-all duration-300 flex flex-col"
>
  <div
    class="h-48 bg-surface-container relative overflow-hidden"
    style={`background-image: url('${image}'); background-size: cover; background-position: center;`}
  >
    <div
      class="absolute inset-0 bg-primary-container/10 group-hover:bg-transparent transition-colors duration-300"
    >
    </div>
    <div class="absolute inset-0 group-hover:scale-105 transition-transform duration-700"
      style={`background-image: url('${image}'); background-size: cover; background-position: center;`}
    >
    </div>
  </div>

  <div class="p-stack-sm flex flex-col flex-grow">
    <div class="mb-unit">
      <span
        class="inline-block px-2 py-1 bg-surface-container-highest text-on-surface-variant font-label-sm text-label-sm rounded uppercase"
      >
        {category}
      </span>
    </div>
    <h4 class="font-headline text-headline-md text-primary-container mb-2 group-hover:text-surface-tint transition-colors duration-200">
      {title}
    </h4>
    <p class="font-body text-body-sm text-on-surface-variant mb-stack-sm flex-grow">
      {description}
    </p>
    <div class="flex gap-2 mt-auto">
      <button
        class="flex-1 border border-outline text-secondary font-label-md text-label-md px-4 py-2 rounded hover:bg-surface-container-highest transition-colors duration-200"
      >
        Chi tiết
      </button>
      <button
        class="flex-1 bg-primary-container text-on-primary font-label-md text-label-md px-4 py-2 rounded hover:opacity-90 transition-opacity duration-200"
      >
        Báo giá
      </button>
    </div>
  </div>
</div>
