---
import { site, footerLinks } from "../../data/site";
---

<footer
  class="w-full border-t border-slate-200 dark:border-slate-800 bg-slate-50 dark:bg-slate-950"
>
  <div
    class="w-full py-12 px-8 max-w-[1280px] mx-auto flex flex-col md:flex-row justify-between items-center gap-6"
  >
    <div class="text-base font-bold text-primary dark:text-blue-200">
      {site.brand}
    </div>
    <div class="font-body text-xs text-slate-500 text-center md:text-left">
      {site.copyright}
    </div>
    <div class="flex flex-wrap justify-center gap-4 font-body text-xs text-slate-500">
      {footerLinks.map((link) => (
        <a
          href={link.href}
          class="text-slate-500 dark:text-slate-400 hover:underline decoration-primary dark:decoration-blue-400 transition-colors"
        >
          {link.label}
        </a>
      ))}
    </div>
  </div>
</footer>
