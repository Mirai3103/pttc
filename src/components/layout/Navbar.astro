---
import Button from "../ui/Button.astro";
import { navItems, site } from "../../data/site";

interface Props {
  activePath?: string;
}

const { activePath = "/" } = Astro.props;
---

<nav
  class="fixed top-0 w-full z-50 border-b border-slate-200 dark:border-slate-800 bg-white/95 dark:bg-slate-900/95 backdrop-blur-md shadow-sm dark:shadow-none"
>
  <div class="flex justify-between items-center h-20 px-8 max-w-[1280px] mx-auto">
    <a
      href="/"
      class="text-lg font-bold text-primary dark:text-blue-100 uppercase tracking-tighter flex items-center gap-2"
    >
      <img
        alt={`${site.brand} Logo`}
        class="h-12 object-contain"
        src={site.logo}
      />
      {site.brand}
    </a>

    <div class="hidden md:flex gap-8 items-center font-headline text-sm font-medium tracking-wide">
      {navItems.map((item) => (
        <a
          href={item.href}
          class={
            item.href === activePath || item.href === `${activePath}#`
              ? "text-primary dark:text-blue-400 border-b-2 border-primary dark:border-blue-400 pb-1"
              : "text-slate-600 dark:text-slate-400 hover:text-blue-700 dark:hover:text-blue-300 transition-colors duration-200"
          }
        >
          {item.label}
        </a>
      ))}
    </div>

    <div class="hidden md:block">
      <Button variant="primary">Yêu cầu báo giá</Button>
    </div>
  </div>
</nav>
