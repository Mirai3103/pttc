---
import { contactCTA } from "../../data/contact";
---

<section class="bg-primary text-on-primary py-stack-lg" data-reveal>
  <div class="max-w-[1280px] mx-auto px-gutter text-center">
    <h2 class="font-headline text-headline-lg mb-stack-sm">
      {contactCTA.title}
    </h2>
    <p class="font-body text-body-lg text-tertiary-fixed mb-stack-md max-w-2xl mx-auto">
      {contactCTA.body}
    </p>
    <div class="flex justify-center gap-stack-sm flex-wrap">
      <a
        href={contactCTA.phoneHref}
        class="bg-on-primary text-primary-container font-label-md text-label-md px-6 py-3 rounded shadow-sm hover:bg-slate-100 transition-colors duration-200 flex items-center gap-2"
      >
        <span class="material-symbols-outlined">phone_in_talk</span>
        {contactCTA.phone} (Mr. Duy)
      </a>
      <a
        href={contactCTA.facebookHref}
        target="_blank"
        rel="noopener noreferrer"
        class="bg-transparent border border-on-primary/40 text-on-primary font-label-md text-label-md px-6 py-3 rounded hover:bg-white/10 transition-colors duration-200 flex items-center gap-2"
      >
        <span class="material-symbols-outlined">thumb_up</span>
        Fanpage Facebook
      </a>
    </div>
  </div>
</section>
