---
import SectionHeading from "../ui/SectionHeading.astro";
import Button from "../ui/Button.astro";
import NewsCard from "../cards/NewsCard.astro";
import { news } from "../../data/site";
---

<section class="py-stack-lg bg-white px-8" id="tin-tuc">
  <div class="max-w-[1280px] mx-auto">
    <SectionHeading
      eyebrow="Cập nhật thị trường"
      title="Tin Tức & Sự Kiện"
      align="bordered"
    >
      <Button slot="cta" variant="outline" class="mt-4 md:mt-0">
        Xem tất cả tin tức
      </Button>
    </SectionHeading>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-gutter" data-stagger>
      {news.map((item) => <NewsCard {...item} />)}
    </div>
  </div>
</section>
