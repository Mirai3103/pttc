---
import ContactInfoCard from "../cards/ContactInfoCard.astro";
import { contactInfoCards, contactFormSubjects } from "../../data/contact";
---

<section class="max-w-[1280px] mx-auto px-gutter py-stack-lg space-y-stack-lg">

  <!-- Info cards: 2 cols × 3 rows -->
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-gutter" data-stagger>
    {contactInfoCards.map((card) => <ContactInfoCard {...card} />)}
  </div>

  <!-- Contact form (full width) -->
  <div data-reveal>
      <div
        class="bg-surface-container-lowest border border-surface-variant shadow-[0px_4px_20px_rgba(0,51,102,0.04)] rounded-lg p-stack-md"
      >
        <h2
          class="font-headline text-headline-lg text-primary mb-stack-sm border-b border-surface-variant pb-unit"
        >
          Gửi thông điệp
        </h2>

        <form action="#" method="POST" class="space-y-stack-sm">
          <!-- Row 1: Name + Company -->
          <div class="grid grid-cols-1 md:grid-cols-2 gap-stack-sm">
            <div>
              <label
                for="name"
                class="block font-label-sm text-label-sm text-on-surface-variant uppercase mb-unit"
              >
                Họ và tên
              </label>
              <input
                id="name"
                name="name"
                type="text"
                placeholder="Nguyễn Văn A"
                class="w-full bg-surface-container-lowest border border-outline-variant rounded focus:border-primary-container focus:ring-1 focus:ring-primary-container font-body text-body-sm px-3 py-2 text-on-surface outline-none transition-colors duration-200"
              />
            </div>
            <div>
              <label
                for="company"
                class="block font-label-sm text-label-sm text-on-surface-variant uppercase mb-unit"
              >
                Công ty
              </label>
              <input
                id="company"
                name="company"
                type="text"
                placeholder="Tên doanh nghiệp"
                class="w-full bg-surface-container-lowest border border-outline-variant rounded focus:border-primary-container focus:ring-1 focus:ring-primary-container font-body text-body-sm px-3 py-2 text-on-surface outline-none transition-colors duration-200"
              />
            </div>
          </div>

          <!-- Row 2: Email + Phone -->
          <div class="grid grid-cols-1 md:grid-cols-2 gap-stack-sm">
            <div>
              <label
                for="email"
                class="block font-label-sm text-label-sm text-on-surface-variant uppercase mb-unit"
              >
                Email
              </label>
              <input
                id="email"
                name="email"
                type="email"
                placeholder="email@domain.com"
                class="w-full bg-surface-container-lowest border border-outline-variant rounded focus:border-primary-container focus:ring-1 focus:ring-primary-container font-body text-body-sm px-3 py-2 text-on-surface outline-none transition-colors duration-200"
              />
            </div>
            <div>
              <label
                for="phone"
                class="block font-label-sm text-label-sm text-on-surface-variant uppercase mb-unit"
              >
                Số điện thoại
              </label>
              <input
                id="phone"
                name="phone"
                type="tel"
                placeholder="090..."
                class="w-full bg-surface-container-lowest border border-outline-variant rounded focus:border-primary-container focus:ring-1 focus:ring-primary-container font-body text-body-sm px-3 py-2 text-on-surface outline-none transition-colors duration-200"
              />
            </div>
          </div>

          <!-- Subject -->
          <div>
            <label
              for="subject"
              class="block font-label-sm text-label-sm text-on-surface-variant uppercase mb-unit"
            >
              Chủ đề
            </label>
            <select
              id="subject"
              name="subject"
              class="w-full bg-surface-container-lowest border border-outline-variant rounded focus:border-primary-container focus:ring-1 focus:ring-primary-container font-body text-body-sm px-3 py-2 text-on-surface outline-none transition-colors duration-200"
            >
              <option value="" disabled selected>Chọn chủ đề liên hệ...</option>
              {contactFormSubjects.map((opt) => (
                <option value={opt.value}>{opt.label}</option>
              ))}
            </select>
          </div>

          <!-- Message -->
          <div>
            <label
              for="message"
              class="block font-label-sm text-label-sm text-on-surface-variant uppercase mb-unit"
            >
              Nội dung chi tiết
            </label>
            <textarea
              id="message"
              name="message"
              rows={5}
              placeholder="Vui lòng cung cấp chi tiết yêu cầu của bạn..."
              class="w-full bg-surface-container-lowest border border-outline-variant rounded focus:border-primary-container focus:ring-1 focus:ring-primary-container font-body text-body-sm px-3 py-2 text-on-surface outline-none resize-none transition-colors duration-200"
            ></textarea>
          </div>

          <!-- Submit -->
          <div class="pt-unit">
            <button
              type="submit"
              class="w-full md:w-auto bg-primary-container text-on-primary font-label-md text-label-md px-8 py-3 rounded shadow-sm hover:bg-primary transition-colors duration-200 flex items-center gap-2 justify-center"
            >
              Gửi yêu cầu
              <span class="material-symbols-outlined text-sm">arrow_forward</span>
            </button>
          </div>
        </form>
      </div>
  </div>
</section>
